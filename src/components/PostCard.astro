---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import TagList from './TagList.astro';
import { getPostUrl } from '../utils/writing';

interface Props {
  post: CollectionEntry<'writing'>;
}

const { post } = Astro.props;
const { title, description, date, tags } = post.data;

// Build the full URL for this post
const postUrl = getPostUrl(post);
---

<article class="mb-10 pb-10 border-b border-gray-100 dark:border-gray-800 last:border-0">
  <h2 class="text-xl font-semibold mb-1">
    <a href={postUrl} class="text-gray-900 dark:text-gray-100 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">
      {title}
    </a>
  </h2>
  <div class="flex flex-wrap items-center gap-3 mb-2">
    <FormattedDate date={date} />
    {tags && tags.length > 0 && <TagList tags={tags} />}
  </div>
  {description && <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">{description}</p>}
</article>
