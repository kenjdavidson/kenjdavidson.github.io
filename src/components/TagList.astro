---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<ul class="flex flex-wrap gap-2 list-none p-0 m-0">
  {
    tags.map((tag) => (
      <li>
        <a
          href={`/writing/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}
          class="inline-block px-2 py-0.5 text-xs font-medium rounded-full bg-brand-50 text-brand-700 hover:bg-brand-100 transition-colors"
        >
          {tag}
        </a>
      </li>
    ))
  }
</ul>
