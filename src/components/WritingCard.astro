---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { getPostUrl } from '../utils/writing';

interface Props {
  post: CollectionEntry<'writing'>;
}

const { post } = Astro.props;
const { title, description, date, tags, featureImage } = post.data;
const postUrl = getPostUrl(post);

const formattedDate = new Intl.DateTimeFormat('en-US', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
}).format(date);
---

<div class="flex flex-col">
  <a href={postUrl} class="group flex-1">
    <article class="relative h-56 rounded-xl overflow-hidden bg-gray-500 dark:bg-gray-800">
      {featureImage && (
        <Image
          src={featureImage}
          alt=""
          class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-60 transition-opacity duration-300"
          widths={[400, 800, 1200]}
          sizes="(min-width: 768px) min(50vw, 600px), 100vw"
        />
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent"></div>
      <div class="relative h-full flex flex-col justify-between p-4">
        <div class="self-end">
          <time datetime={date.toISOString()} class="text-gray-300 text-xs font-medium">
            {formattedDate}
          </time>
        </div>
        <div>
          <h2 class="text-white font-bold text-lg leading-snug mb-1 group-hover:text-brand-300 transition-colors duration-200">
            {title}
          </h2>
          {description && (
            <p class="text-gray-300 text-xs line-clamp-2 mb-2">{description}</p>
          )}
          {tags && tags.length > 0 && (
            <div class="flex flex-wrap gap-1">
              {tags.slice(0, 3).map((tag) => (
                <span class="px-2 py-0.5 text-xs bg-white/20 text-white rounded-full">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    </article>
  </a>
</div>
