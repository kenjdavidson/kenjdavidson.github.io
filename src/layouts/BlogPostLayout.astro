---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TagList from '../components/TagList.astro';

interface Props {
  entry: CollectionEntry<'writing'>;
}

const { entry } = Astro.props;
const { title, description, date, tags } = entry.data;
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="mb-10">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4">{title}</h1>
      <div class="flex flex-wrap items-center gap-4 text-gray-500 dark:text-gray-400 text-sm">
        <FormattedDate date={date} />
        {tags && tags.length > 0 && <TagList tags={tags} />}
      </div>
      {description && <p class="mt-4 text-lg text-gray-600 dark:text-gray-300">{description}</p>}
    </header>
    <div class="prose prose-lg dark:prose-invert max-w-none">
      <slot />
    </div>
    <footer class="mt-16 pt-8 border-t border-gray-200 dark:border-gray-700">
      <a href="/writing" class="text-brand-600 hover:text-brand-700 font-medium">
        &larr; Back to Writing
      </a>
    </footer>
  </article>
</BaseLayout>
