---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TagList from '../components/TagList.astro';
import { getPostUrl } from '../utils/writing';

interface Props {
  entry: CollectionEntry<'writing'>;
  prev?: CollectionEntry<'writing'> | null;
  next?: CollectionEntry<'writing'> | null;
}

const { entry, prev, next } = Astro.props;
const { title, description, date, tags } = entry.data;
---

<BaseLayout title={title} description={description}>
  <article class="max-w-5xl mx-auto w-full px-4">
    <header class="mb-10">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4">{title}</h1>
      <div class="flex flex-wrap items-center gap-4 text-gray-500 dark:text-gray-400 text-sm">
        <FormattedDate date={date} />
        {tags && tags.length > 0 && <TagList tags={tags} />}
      </div>
      {description && <p class="mt-4 text-lg text-gray-600 dark:text-gray-300">{description}</p>}
    </header>
    <div class="prose prose-lg dark:prose-invert max-w-none">
      <slot />
    </div>
    <footer class="mt-16 pt-8 border-t border-gray-200 dark:border-gray-700">
      <nav class="flex flex-col gap-6 sm:flex-row sm:justify-between" aria-label="Article navigation">
        <div class="flex-1">
          {prev && (
            <a href={getPostUrl(prev)} class="group flex flex-col gap-1 text-sm text-gray-500 dark:text-gray-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">
              <span class="text-xs uppercase tracking-wide font-medium">&larr; Previous</span>
              <span class="text-base font-semibold text-gray-900 dark:text-gray-100 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">{prev.data.title}</span>
            </a>
          )}
        </div>
        <div class="flex-none self-center">
          <a href="/writing" class="text-brand-600 hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300 font-medium text-sm">
            All Articles
          </a>
        </div>
        <div class="flex-1 sm:text-right">
          {next && (
            <a href={getPostUrl(next)} class="group flex flex-col gap-1 text-sm text-gray-500 dark:text-gray-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors sm:items-end">
              <span class="text-xs uppercase tracking-wide font-medium">Next &rarr;</span>
              <span class="text-base font-semibold text-gray-900 dark:text-gray-100 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">{next.data.title}</span>
            </a>
          )}
        </div>
      </nav>
    </footer>
  </article>
</BaseLayout>
