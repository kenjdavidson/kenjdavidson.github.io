---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <div class="max-w-5xl mx-auto w-full px-4">
  <div class="text-center py-20">
    <h1 class="text-6xl font-bold text-brand-600 mb-4">404</h1>
    <h2 class="text-2xl font-semibold text-gray-900 mb-6">Welp…</h2>
    <p class="text-gray-600 mb-8 max-w-md mx-auto">
      Looks like you should have taken a left turn at Albuquerque! There isn't much (I know) so
      you've only got a couple options:
    </p>
    <ul class="flex flex-col sm:flex-row justify-center gap-4">
      <li>
        <a href="/" class="inline-block px-6 py-3 rounded-lg bg-brand-600 text-white font-medium hover:bg-brand-700 transition-colors">
          Home
        </a>
      </li>
      <li>
        <a href="/writing" class="inline-block px-6 py-3 rounded-lg border border-gray-300 text-gray-700 font-medium hover:border-brand-600 hover:text-brand-600 transition-colors">
          Writing
        </a>
      </li>
      <li>
        <a href="/about" class="inline-block px-6 py-3 rounded-lg border border-gray-300 text-gray-700 font-medium hover:border-brand-600 hover:text-brand-600 transition-colors">
          About
        </a>
      </li>
    </ul>
  </div>
  </div>
</BaseLayout>
