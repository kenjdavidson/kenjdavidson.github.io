---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allTimeline = await getCollection('timeline', ({ data }) => !data.draft);
const timeline = allTimeline.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="About" description="A little bit about Ken Davidson — husband, father, golfer, and developer.">
  <h1 class="text-4xl font-bold text-gray-900 mb-6">Heyoh!</h1>

  <div class="prose prose-lg max-w-none mb-16">
    <p>
      So, I'm <strong>Ken</strong>. I'm not a big enough deal (nor trust any of my friends) to have
      someone write me a biography! To get through this quickly and to my level of writing, let me
      provide you with the <em>communication of the Gods</em> (a.k.a. point form)!!
    </p>

    <h2>Husbanding &amp; Fathering</h2>
    <ul>
      <li>I'm married to a wonderfully amazing (and more importantly patient) woman, Sue.</li>
      <li>We've been together/married for north of 10 years.</li>
      <li>We've got a crazy and energetic (my doppelgänger of a) son, Carson.</li>
      <li>
        We try to be outside as much as possible; watching Carson scoot around the block, checking
        out <a href="https://www.conservationhalton.ca/parks">Halton's conservation areas</a>,
        building a luge track on the front lawn, or any number of other ridiculous things we find
        ourselves doing.
      </li>
      <li>When inside we're in <em>other room</em> making money playing <strong>Axe Ball</strong>.</li>
    </ul>

    <h2>Golfing</h2>
    <ul>
      <li>I played baseball through my youth and didn't get into golf until my mid twenties.</li>
      <li>Even with ~20 years under my belt, I'm still pretty terrible (14 handicap).</li>
      <li>I try to play twice a week (sprinkling in a third whenever the opportunity presents itself).</li>
      <li>If you're a bogey golfer, feel free to hit me up for some loonie skins around the GTA.</li>
      <li>What's in the bag? Callaway Rogue Driver/3 Wood, Cobra King Max 4i-GW, 56°, 60°</li>
    </ul>

    <h2>Developing</h2>
    <ul>
      <li>
        I graduated from <a href="https://ryerson.ca">Ryerson University</a> with a degree in{' '}
        <a href="https://www.ryerson.ca/programs/undergraduate/computer-science/">Computer Science</a>.
      </li>
      <li>
        I went through a string of non-development roles including sales, support, implementation
        and design before getting back into the development game.
      </li>
      <li>
        I'm currently working as a Senior Software Engineer. The main technologies I work with are
        <code>Java</code>, <code>Kotlin</code>, and <code>React</code> on Spring Boot.
      </li>
      <li>
        My first attempt at playing with React Native ended up in releasing and maintaining the{' '}
        <a href="https://kenjdavidson.com/react-native-bluetooth-classic">React Native Bluetooth Classic</a>{' '}
        library.
      </li>
      <li>
        I'm always attempting to work my way through new languages and frameworks.
      </li>
    </ul>
  </div>

  <!-- Contact -->
  <section class="mb-16 p-6 rounded-xl bg-gray-50 border border-gray-100">
    <h2 class="text-2xl font-bold text-gray-900 mb-4">Get in Touch</h2>
    <p class="text-gray-600 mb-6">
      Thanks for swinging by! Whether you're looking for assistance with{' '}
      <a href="https://kenjdavidson.com/react-native-bluetooth-classic" class="text-brand-600 hover:underline">Bluetooth Classic</a>,
      a role you're head hunting for, or maybe a custom project you're looking to start — I do my
      best to respond within the day.
    </p>
    <ul class="space-y-3 text-sm">
      <li>
        <span class="text-gray-500 font-medium">Email:</span>{' '}
        <a href="mailto:hello@kenjdavidson.com" class="text-brand-600 hover:underline ml-1">
          hello@kenjdavidson.com
        </a>
      </li>
      <li>
        <span class="text-gray-500 font-medium">GitHub:</span>{' '}
        <a
          href="https://github.com/kenjdavidson"
          class="text-brand-600 hover:underline ml-1"
          target="_blank"
          rel="noopener noreferrer"
        >
          github.com/kenjdavidson
        </a>
      </li>
      <li>
        <span class="text-gray-500 font-medium">LinkedIn:</span>{' '}
        <a
          href="https://linkedin.com/in/kenjdavidson"
          class="text-brand-600 hover:underline ml-1"
          target="_blank"
          rel="noopener noreferrer"
        >
          linkedin.com/in/kenjdavidson
        </a>
      </li>
      <li>
        <span class="text-gray-500 font-medium">Instagram:</span>{' '}
        <a
          href="https://instagram.com/kenjdavidson"
          class="text-brand-600 hover:underline ml-1"
          target="_blank"
          rel="noopener noreferrer"
        >
          @kenjdavidson
        </a>
      </li>
    </ul>
  </section>

  <!-- Timeline -->
  {
    timeline.length > 0 && (
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-8">Timeline</h2>
        <ol class="relative border-l border-gray-200 space-y-8 ml-3">
          {timeline.map((item) => (
            <li class="ml-6">
              <span class="absolute -left-3 flex h-6 w-6 items-center justify-center rounded-full bg-brand-100 ring-8 ring-white">
                <span class="h-2 w-2 rounded-full bg-brand-500" />
              </span>
              <div class="flex flex-wrap items-center gap-2 mb-1">
                <h3 class="text-base font-semibold text-gray-900">{item.data.title}</h3>
                {item.data.category && (
                  <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-brand-50 text-brand-700">
                    {item.data.category}
                  </span>
                )}
              </div>
              {item.data.subtitle && (
                <p class="text-sm text-gray-500 mb-1">{item.data.subtitle}</p>
              )}
              <time class="text-xs text-gray-400">
                {new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long' }).format(
                  item.data.date
                )}
              </time>
              {item.data.website && (
                <p class="mt-1">
                  <a
                    href={item.data.website}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs text-brand-600 hover:underline"
                  >
                    {item.data.website}
                  </a>
                </p>
              )}
            </li>
          ))}
        </ol>
      </section>
    )
  }
</BaseLayout>
