---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const projects = allProjects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<BaseLayout title="Projects" description="A selection of open source and personal projects.">
  <div class="max-w-5xl mx-auto w-full px-4">
  <h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100 mb-10">Projects</h1>

  <div class="space-y-12">
    {
      projects.map((project) => {
        const slug = project.data.slug ?? `/projects/${project.id.replace(/\/index\.mdx?$/, '')}`;
        return (
          <article class="border-b border-gray-100 dark:border-gray-800 pb-12 last:border-0">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-2">
              <a href={slug} class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors">
                {project.data.title}
              </a>
            </h2>
            {project.data.description && (
              <p class="text-gray-600 dark:text-gray-300 mb-4">{project.data.description}</p>
            )}
            <div class="flex gap-4">
              <a
                href={slug}
                class="inline-flex items-center px-4 py-2 rounded-lg bg-brand-600 text-white text-sm font-medium hover:bg-brand-700 transition-colors"
              >
                Learn more
              </a>
              {project.data.github && (
                <a
                  href={project.data.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 text-sm font-medium hover:border-brand-600 hover:text-brand-600 dark:hover:border-brand-400 dark:hover:text-brand-400 transition-colors"
                >
                  GitHub &rarr;
                </a>
              )}
            </div>
          </article>
        );
      })
    }
  </div>
  </div>
</BaseLayout>
