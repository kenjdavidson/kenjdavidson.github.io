---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const allPosts = await getCollection('writing', ({ data }) => !data.draft);

// Build tag => count map
const tagMap = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags ?? []) {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  }
}

const tags = [...tagMap.entries()].sort((a, b) => a[0].localeCompare(b[0]));
---

<BaseLayout title="Tags" description="Browse articles by tag.">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-4xl font-bold text-gray-900">Tags</h1>
    <a href="/writing" class="text-brand-600 hover:text-brand-700 text-sm font-medium">
      &larr; All writing
    </a>
  </div>

  <div class="flex flex-wrap gap-3">
    {
      tags.map(([tag, count]) => (
        <a
          href={`/writing/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}
          class="px-4 py-2 rounded-full bg-gray-100 text-gray-700 hover:bg-brand-50 hover:text-brand-700 transition-colors text-sm font-medium"
        >
          {tag} <span class="text-gray-400 ml-1">({count})</span>
        </a>
      ))
    }
  </div>
</BaseLayout>
